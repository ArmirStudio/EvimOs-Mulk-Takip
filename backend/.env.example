# Required for backend startup
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required by some backend flows and smoke checks
SUPABASE_ANON_KEY=your-anon-key

# Optional: falls back to defaults in backend/main.py when omitted
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://localhost:8083,http://127.0.0.1:8083,http://localhost:19000,https://your-frontend-domain.example

# Optional auth resolve limiter
AUTH_RESOLVE_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RESOLVE_RATE_LIMIT_MAX_REQUESTS=20
